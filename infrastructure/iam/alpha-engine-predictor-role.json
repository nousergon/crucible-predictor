{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ResearchBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::alpha-engine-research",
        "arn:aws:s3:::alpha-engine-research/*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:711398986525:log-group:/aws/lambda/alpha-engine-predictor-inference:*",
        "arn:aws:logs:us-east-1:711398986525:log-group:/aws/lambda/alpha-engine-predictor-regime-substrate:*",
        "arn:aws:logs:us-east-1:711398986525:log-group:/aws/lambda/alpha-engine-predictor-regime-retrospective-eval:*"
      ]
    },
    {
      "Sid": "DeployDriftProbe",
      "Effect": "Allow",
      "Action": [
        "cloudformation:DescribeStacks",
        "states:DescribeStateMachine"
      ],
      "Resource": [
        "arn:aws:cloudformation:us-east-1:711398986525:stack/alpha-engine-orchestration/*",
        "arn:aws:states:us-east-1:711398986525:stateMachine:alpha-engine-saturday-pipeline",
        "arn:aws:states:us-east-1:711398986525:stateMachine:alpha-engine-weekday-pipeline"
      ]
    },
    {
      "Sid": "PutAlphaEngineMetrics",
      "Effect": "Allow",
      "Action": "cloudwatch:PutMetricData",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "cloudwatch:namespace": "AlphaEngine/*"
        }
      }
    }
  ]
}
